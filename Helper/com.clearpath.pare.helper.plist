<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
    launchd plist for the Pare privileged helper.

    At install time this file is copied to
    `Pare.app/Contents/Library/LaunchDaemons/com.clearpath.pare.helper.plist`
    and registered via SMAppService.daemon(plistName:). The matching helper
    binary lives at `Pare.app/Contents/MacOS/com.clearpath.pare.helper`.

    `AssociatedBundleIdentifiers` must match the App's CFBundleIdentifier so
    macOS shows a single Login Items entry under the app's display name.
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.clearpath.pare.helper</string>

    <key>BundleProgram</key>
    <string>Contents/MacOS/com.clearpath.pare.helper</string>

    <key>MachServices</key>
    <dict>
        <key>com.clearpath.pare.helper</key>
        <true/>
    </dict>

    <key>AssociatedBundleIdentifiers</key>
    <array>
        <string>com.clearpath.pare</string>
    </array>

    <key>StandardErrorPath</key>
    <string>/var/log/com.clearpath.pare.helper.err.log</string>

    <key>StandardOutPath</key>
    <string>/var/log/com.clearpath.pare.helper.out.log</string>

    <key>ProcessType</key>
    <string>Interactive</string>
</dict>
</plist>
